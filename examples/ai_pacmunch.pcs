################################################################################
 {
   "project_metadata": {
     "name": "PAC-MUNCH",
     "version": "11.0",
     "genre": "Dungeon Crawler / Arcade",
     "engine_constraints": "Text-Mode (64x32), Global Scope, Atomic Execution"
   },
   "core_algorithms": {
     "ghost_ai": "Manhattan Distance Priority. Calculates |Px-Gx| and |Py-Gy|. Attempts to reduce the largest delta first. If blocked, attempts the secondary axis. Prevents 'staircase' movement and wall-sticking.",
     "map_generation": "Procedural Rectangles. Uses a 'draw_rect' helper to carve walls into a pellet-filled grid. Automatically decrements 'Pellets_Left' when overwriting empty space to keep win-state math valid.",
     "collision_detection": "Index-Based Lookup. Converts 2D coords (x,y) to 1D index (y*Width + x) to check 'Map[]' values before allowing movement."
   },
   "critical_fixes_log": {
     "infinite_loop_trap": "The command 'loop_while TRUE' checks the literal value '1' forever. Loops must depend on 'Condexp' variables updated INSIDE the loop.",
     "screen_buffer_collapse": "PCS/GTK buffers render 0-height lines if empty. Always pre-fill the screen with an 'Aether' of spaces (ASCII 32) before drawing coordinates.",
     "font_fallback_glitch": "Using exotic Unicode (Adlam/Aboriginal) triggers variable-width font fallback, breaking grid alignment. Use Geometric Shapes (U+25xx) for reliable monospacing.",
     "exit_segmentation": "The 'exit' command acts as EOF. Multiple exit points make code below them unreachable/invisible. Use a single 'final_shutdown' label at the bottom and jump to it."
   },
   "agent_guidelines": {
     "atomic_thinking": "Do not nest math. Do not assume 'if (x > y)' works. Use 'set_condexp' then 'do_if Condexp'. One thought per line.",
     "coordinate_systems": "Verify the target terminal's Y-Axis. Standard terminals are Top-Left (Y+ goes Down). Cartesian plots are Bottom-Left (Y+ goes Up). Map inputs explicitly.",
     "variable_safety": "All variables are global. Loop counters (idx, loop_x) WILL be clobbered if a subroutine uses them. Use dedicated counters for nested logic."
   }
 }
