Pardus pcs 1
verbosity 3

################################################
# Testing array variables and autocasting.     #
# Also note 'verbosity 3' so demonstrating     #
# verbose output.                              #
################################################

# 1. Define the Data Array
def_array float MyData 5 0.0
set_var MyData[0] 10.5
set_var MyData[1] 21.0
set_var MyData[2] 31.5
set_var MyData[3] 42.0
set_var MyData[4] 52.5

# 2. Define an Integer Index Map
def_array int IntMap 3 0
set_var IntMap[0] 4
set_var IntMap[1] 2

# 3. Define a String Index Map (Testing Autocasting)
def_array string StrMap 2 0
set_var StrMap[0] 3
set_var StrMap[1] 1

def_var string msg _

def_func main
  set_str msg --- Recursive Array Test Start ---
  print_value msg 2

  # Test 1: Integer Array indexing Float Array
  # Should resolve: MyData[ IntMap[0] ] -> MyData[4] -> 52.5
  set_str msg Testing IntMap[0] (should be 52.5):
  print_value msg 2
  print_value MyData[IntMap[0]]

  # Test 2: String Array indexing Float Array (Autocasting Test)
  # Should resolve: MyData[ StrMap[0] ] -> MyData["3"] -> MyData[3] -> 42.0
  set_str msg Testing StrMap[0] (should be 42.0):
  print_value msg 2
  print_value MyData[StrMap[0]]

  # Test 3: Double Nesting (The "Spaghetti" Test)
  # Resolves: MyData[ IntMap[ StrMap[1] ] ] 
  # -> StrMap[1] is 1
  # -> IntMap[1] is 2
  # -> MyData[2] is 31.5
  set_str msg Testing Double Nest (should be 31.5):
  print_value msg 2
  print_value MyData[IntMap[StrMap[1]]]

return
exit

